apiVersion: v1
kind: ConfigMap
metadata:
  name: application-dashboard
  namespace: observability
  labels:
    grafana_dashboard: "1"
data:
  application-dashboard.json: |
    {
      "title": "Booking Platform - Application Overview",
      "uid": "booking-application",
      "tags": ["application", "booking", "microservices"],
      "schemaVersion": 38,
      "refresh": "15s",
      "time": { "from": "now-30m", "to": "now" },
      "templating": {
        "list": [
          {
            "name": "release",
            "type": "custom",
            "label": "Release",
            "query": "bookmytrip-dev,bookmytrip-staging,bookmytrip-prod",
            "current": { "text": "bookmytrip-dev", "value": "bookmytrip-dev" }
          }
        ]
      },
      "panels": [
        {
          "id": 1,
          "title": "HTTP Request Rate",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
          "targets": [
            { "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (job)", "legendFormat": "{{job}}" },
            { "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (job)", "legendFormat": "{{job}}" }
          ]
        },
        {
          "id": 2,
          "title": "Average Response Time",
          "type": "timeseries",
          "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
          "targets": [
            { "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])", "legendFormat": "{{job}}" }
          ]
        },
        {
          "id": 3,
          "title": "5xx Errors",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
          "targets": [
            { "expr": "sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) by (job)", "legendFormat": "{{job}}" },
            { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (job)", "legendFormat": "{{job}}" }
          ]
        },
        {
          "id": 4,
          "title": "Top Application Logs",
          "type": "logs",
          "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
          "datasource": { "type": "loki", "uid": "loki" },
          "targets": [
            { "expr": "{namespace=\"app-dev\"}" }
          ]
        },
        {
          "id": 5,
          "title": "Recent Traces",
          "type": "traces",
          "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
          "datasource": { "type": "tempo", "uid": "tempo" },
          "targets": [
            { "queryType": "search" }
          ]
        },
        {
          "id": 6,
          "title": "Pod Restarts",
          "type": "stat",
          "gridPos": { "x": 0, "y": 26, "w": 6, "h": 4 },
          "targets": [
            { "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"app-dev\"})" }
          ]
        },
        {
          "id": 7,
          "title": "Active Pods",
          "type": "stat",
          "gridPos": { "x": 6, "y": 26, "w": 6, "h": 4 },
          "targets": [
            { "expr": "count(kube_pod_info{namespace=\"app-dev\"})" }
          ]
        },
        {
          "id": 8,
          "title": "CPU Usage",
          "type": "timeseries",
          "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
          "targets": [
            { "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"app-dev\"}[5m])) by (pod)", "legendFormat": "{{pod}}" }
          ]
        }
      ]
    }